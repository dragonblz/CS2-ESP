<Window x:Class="FoxSense.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FoxSense" Width="420" Height="560"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- Toggle button style -->
        <Style x:Key="ToggleStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="#2A2A3E" CornerRadius="6" Padding="12,0">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF4B2B" Offset="0"/>
                                            <GradientStop Color="#FF416C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider style -->
        <Style x:Key="SliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Foreground" Value="#FF4B2B"/>
        </Style>

        <!-- Tab button style -->
        <Style x:Key="TabStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#1E1E32" CornerRadius="8" Padding="16,0">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2A3E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label style -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Resources>

    <!-- Main border with glassmorphism -->
    <Border CornerRadius="16" Margin="8">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E61A1A2E" Offset="0"/>
                <GradientStop Color="#E6141428" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="#80000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>  <!-- Header -->
                <RowDefinition Height="44"/>  <!-- Tabs -->
                <RowDefinition Height="*"/>   <!-- Content -->
                <RowDefinition Height="32"/>  <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ═══ HEADER ═══ -->
            <Border Grid.Row="0" Padding="16,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🦊" FontSize="20" Margin="0,0,8,0"/>
                        <TextBlock Text="FOXSENSE" FontSize="16" FontFamily="Segoe UI Black"
                                   Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="v2.0" FontSize="10" Foreground="#666"
                                   VerticalAlignment="Center" Margin="8,2,0,0"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="BtnClose_Click" Cursor="Hand" FontSize="14"
                            Foreground="#666" Background="Transparent" BorderThickness="0"
                            Width="32" Height="32"/>
                </Grid>
            </Border>

            <!-- ═══ TAB BAR ═══ -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="16,0" HorizontalAlignment="Center">
                <Button x:Name="btnTabVisuals" Content="👁 VISUALS" Tag="visuals"
                        Style="{StaticResource TabStyle}" Width="110" Click="BtnTab_Click" Margin="0,0,6,0"/>
                <Button x:Name="btnTabAimbot" Content="🎯 AIMBOT" Tag="aimbot"
                        Style="{StaticResource TabStyle}" Width="110" Click="BtnTab_Click" Margin="0,0,6,0"/>
                <Button x:Name="btnTabSettings" Content="⚙ SETTINGS" Tag="settings"
                        Style="{StaticResource TabStyle}" Width="110" Click="BtnTab_Click"/>
            </StackPanel>

            <!-- ═══ VISUALS TAB ═══ -->
            <ScrollViewer Grid.Row="2" x:Name="panelVisuals" Margin="16,8"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ToggleButton x:Name="btnEspToggle" Content="ESP: OFF" IsChecked="False"
                                  Style="{StaticResource ToggleStyle}" Margin="0,4"
                                  Checked="BtnEsp_Checked" Unchecked="BtnEsp_Unchecked"/>

                    <TextBlock Text="FEATURES" Margin="0,10,0,4" FontSize="10" Foreground="#555"/>
                    <ToggleButton x:Name="btnBox" Content="📦 Box ESP" IsChecked="True"
                                  Style="{StaticResource ToggleStyle}" Margin="0,2"/>
                    <ToggleButton x:Name="btnSkeleton" Content="🦴 Skeleton" IsChecked="True"
                                  Style="{StaticResource ToggleStyle}" Margin="0,2"/>
                    <ToggleButton x:Name="btnHealthBar" Content="❤ Health Bar" IsChecked="True"
                                  Style="{StaticResource ToggleStyle}" Margin="0,2"/>
                    <ToggleButton x:Name="btnNames" Content="🏷 Names" IsChecked="True"
                                  Style="{StaticResource ToggleStyle}" Margin="0,2"/>
                    <ToggleButton x:Name="btnDistance" Content="📏 Distance" IsChecked="True"
                                  Style="{StaticResource ToggleStyle}" Margin="0,2"/>
                    <ToggleButton x:Name="btnSnapLines" Content="📍 Snap Lines" IsChecked="False"
                                  Style="{StaticResource ToggleStyle}" Margin="0,2"/>
                    <ToggleButton x:Name="btnEnemyOnly" Content="Enemies Only" IsChecked="True"
                                  Style="{StaticResource ToggleStyle}" Margin="0,2"
                                  Checked="BtnEnemyOnly_Checked" Unchecked="BtnEnemyOnly_Unchecked"/>

                    <TextBlock Text="ESP COLOR" Margin="0,10,0,4" FontSize="10" Foreground="#555"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="R" Grid.Row="0" Grid.Column="0" Foreground="#FF4444"/>
                        <Slider x:Name="sliderR" Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255"
                                Value="255" Style="{StaticResource SliderStyle}"/>
                        <TextBlock Text="G" Grid.Row="1" Grid.Column="0" Foreground="#44FF44"/>
                        <Slider x:Name="sliderG" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255"
                                Value="75" Style="{StaticResource SliderStyle}"/>
                        <TextBlock Text="B" Grid.Row="2" Grid.Column="0" Foreground="#4444FF"/>
                        <Slider x:Name="sliderB" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255"
                                Value="43" Style="{StaticResource SliderStyle}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ AIMBOT TAB ═══ -->
            <ScrollViewer Grid.Row="2" x:Name="panelAimbot" Margin="16,8"
                          VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                <StackPanel>
                    <ToggleButton x:Name="btnAimToggle" Content="Aimbot: OFF" IsChecked="False"
                                  Style="{StaticResource ToggleStyle}" Margin="0,4"
                                  Checked="BtnAim_Checked" Unchecked="BtnAim_Unchecked"/>

                    <TextBlock Text="FOV RADIUS" Margin="0,10,0,2" FontSize="10" Foreground="#555"/>
                    <Grid>
                        <Slider x:Name="sliderFov" Minimum="20" Maximum="250" Value="80"
                                Style="{StaticResource SliderStyle}"/>
                        <TextBlock x:Name="txtFovValue" Text="80" HorizontalAlignment="Right"
                                   Foreground="#FF4B2B" FontSize="12" FontFamily="Segoe UI Bold"/>
                    </Grid>

                    <TextBlock Text="SMOOTHING" Margin="0,10,0,2" FontSize="10" Foreground="#555"/>
                    <Grid>
                        <Slider x:Name="sliderSmooth" Minimum="1" Maximum="15" Value="5"
                                Style="{StaticResource SliderStyle}"/>
                        <TextBlock x:Name="txtSmoothValue" Text="5" HorizontalAlignment="Right"
                                   Foreground="#FF4B2B" FontSize="12" FontFamily="Segoe UI Bold"/>
                    </Grid>

                    <TextBlock Text="BONE TARGET" Margin="0,10,0,4" FontSize="10" Foreground="#555"/>
                    <ComboBox x:Name="comboBone" SelectedIndex="0" Height="30"
                              Background="#2A2A3E" Foreground="White" BorderThickness="0"
                              FontFamily="Segoe UI" FontSize="12">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Background" Value="White"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBoxItem Content="🧠 Head"/>
                        <ComboBoxItem Content="🦴 Neck"/>
                        <ComboBoxItem Content="💪 Chest"/>
                    </ComboBox>

                    <TextBlock Text="AIM KEY" Margin="0,12,0,4" FontSize="10" Foreground="#555"/>
                    <Button x:Name="btnKeyBind" Content="🎯 Mouse1" Height="32"
                            Style="{StaticResource TabStyle}" Click="BtnKeyBind_Click"/>

                    <ToggleButton x:Name="btnAimEnemyOnly" Content="Enemies Only" IsChecked="True"
                                  Style="{StaticResource ToggleStyle}" Margin="0,8"/>

                    <ToggleButton x:Name="btnShowFov" Content="👁 Show FOV Circle" IsChecked="True"
                                  Style="{StaticResource ToggleStyle}" Margin="0,2"/>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ SETTINGS TAB ═══ -->
            <ScrollViewer Grid.Row="2" x:Name="panelSettings" Margin="16,8"
                          VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="GUI TOGGLE KEY" Margin="0,4,0,4" FontSize="10" Foreground="#555"/>
                    <Button x:Name="btnGuiKey" Content="🎮 LAlt" Height="32"
                            Style="{StaticResource TabStyle}" Click="BtnGuiKey_Click"/>

                    <Border Margin="0,20,0,0" Padding="12" CornerRadius="8" Background="#16213E">
                        <StackPanel>
                            <TextBlock Text="FOXSENSE v2.0" FontSize="14" Foreground="White"
                                       FontFamily="Segoe UI Black"/>
                            <TextBlock Text="External CS2 ESP + Soft Aimbot" Foreground="#888" Margin="0,4,0,0"/>
                            <TextBlock Text="Direct Syscall Engine • Zero Hook Surface" Foreground="#555" Margin="0,2,0,0"/>
                            <TextBlock Foreground="#333" Margin="0,8,0,0" FontSize="9"
                                       Text="Built with verified offsets from C++ fuzzer session"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="3" Padding="16,0" Background="#0D0D1A"
                    CornerRadius="0,0,16,16">
                <Grid>
                    <TextBlock x:Name="txtStatus" Text="⏳ Waiting for CS2..."
                               VerticalAlignment="Center" Foreground="#666" FontSize="10"/>
                    <TextBlock x:Name="txtFps" Text="" HorizontalAlignment="Right"
                               VerticalAlignment="Center" Foreground="#444" FontSize="10"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
